POSTGRES_DB=groundwater
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=80

JWT_SECRET_KEY=replace-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Frontend build-time variables
VITE_API_BASE=/api
VITE_ENABLE_LIVE_API=true
VITE_LOCAL_DATA_ONLY=false

# Optional CORS override for backend (mainly needed if frontend is hosted separately)
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Deterministic bootstrap controls
BOOTSTRAP_MODE=full
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
DATA_VERSION=
